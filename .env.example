# Required: embeddings and the default LLM provider both use Google.
GOOGLE_API_KEY=""
# Optional: only needed when LLM_PROVIDER=groq
GROQ_API_KEY=""
GROQ_MAX_RETRIES=8
# Optional: which configured LLM provider to use ("google" or "groq"). Defaults to google.
LLM_PROVIDER="groq"
# Optional: only needed by run_evaluations.py (LangSmith evaluation harness)
LANGSMITH_API_KEY=""
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_PROJECT=""

CONFIG_PATH='config/config.yaml'

RAG_CACHE_SIZE=32

EVAL_K = 5
EVAL_CHUNK_SIZE = 1000
EVAL_OVERLAP = 200
EVAL_LIMIT = 3
# NOTE: OPENAI_API_KEY is no longer used by the app (OpenAI is commented out in
# model_loader.py). The previously committed key here should be rotated/revoked.
#OPENAI_API_KEY=""
